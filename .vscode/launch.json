{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run dvizok",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/dvizok.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
      "environment": [
        {
          "name": "PATH",
          "value": "${env:PATH};C:/dev/SDL3-3.2.20/x86_64-w64-mingw32/bin"
        }
      ],
      "preLaunchTask": "build-sdl"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "c:/dev",
      "program": "c:/dev/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}